#!/bin/sh /etc/rc.common
# Copyright (C) 2024-2026, hrimfaxi

START=75
USE_PROCD=1

PROG=/usr/bin/tsubamegaeshi-rs
CONF_DIR=/etc/tsubamegaeshi-rs
CONF_FILE=$CONF_DIR/config.toml
RULE_DIR=$CONF_DIR/rule
REDIRECT_LOCK_FILE=/etc/tsubamegaeshi-rs/redirect.lock

# Escape a value for safe embedding in a TOML double-quoted string
toml_escape() {
	printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

get_config() {
	config_get enabled $1 enabled 0
	config_get listen_port $1 listen_port 5336
	config_get listen_address $1 listen_address "127.0.0.1"
	config_get log_level $1 log_level "info"
	config_get domestic_dns $1 domestic_dns "223.5.5.5"
	config_get foreign_dns $1 foreign_dns "8.8.8.8"
	config_get query_timeout_sec $1 query_timeout_sec 10
	config_get special_suffixes $1 special_suffixes ""
	config_get special_upstream $1 special_upstream ""
	config_get mmdb_path $1 mmdb_path "/etc/tsubamegaeshi-rs/Country-only-cn-private.mmdb"
	config_get domestic_countries $1 domestic_countries "CN"
	config_get gfwlist $1 gfwlist 1
	config_get gfwlist_path $1 gfwlist_path "/etc/tsubamegaeshi-rs/gfwlist.txt"
	config_get gfbloom_fp_rate $1 gfbloom_fp_rate 0.001
	config_get adblock $1 adblock 0
	config_get adblock_path $1 adblock_path "/etc/tsubamegaeshi-rs/adblockdomainlite.txt"
	config_get adblock_fp_rate $1 adblock_fp_rate 0.001
	config_get cache_size $1 cache_size 4096
	config_get ipv4_list $1 ipv4_list "/etc/tsubamegaeshi-rs/ipv4.txt"
	config_get ipv6_list $1 ipv6_list "/etc/tsubamegaeshi-rs/ipv6.txt"
	config_get max_polluted_packets $1 max_polluted_packets 5
	config_get trust_domestic_nodata_reply $1 trust_domestic_nodata_reply 0
	config_get redirect $1 redirect 0
	config_get disable_ipv6 $1 disable_ipv6 0
	config_get max_in_flight $1 max_in_flight 128
}

generate_config() {
	mkdir -p $CONF_DIR
	mkdir -p $RULE_DIR

	# Sanitize numeric values
	case "$cache_size" in ''|*[!0-9]*) cache_size=4096 ;; esac
	case "$query_timeout_sec" in ''|*[!0-9]*) query_timeout_sec=10 ;; esac
	case "$max_in_flight" in ''|*[!0-9]*) max_in_flight=128 ;; esac
	case "$max_polluted_packets" in ''|*[!0-9]*) max_polluted_packets=5 ;; esac
	case "$gfbloom_fp_rate" in ''|*[!0-9.]*) gfbloom_fp_rate=0.001 ;; esac
	case "$adblock_fp_rate" in ''|*[!0-9.]*) adblock_fp_rate=0.001 ;; esac

	local enable_ipv6
	[ "$disable_ipv6" -eq 0 ] && enable_ipv6="true" || enable_ipv6="false"
	local trust_nodata
	[ "$trust_domestic_nodata_reply" -eq 1 ] && trust_nodata="true" || trust_nodata="false"

	# Wrap IPv6 address in brackets
	local listen_str
	case "$listen_address" in
		*:*) listen_str="[${listen_address}]:${listen_port}" ;;
		*)   listen_str="${listen_address}:${listen_port}" ;;
	esac

	# Escape string values for TOML safety
	local _log_level _domestic_dns _foreign_dns _mmdb_path _ipv4_list _ipv6_list
	local _gfwlist_path _adblock_path _special_upstream
	_log_level="$(toml_escape "$log_level")"
	_domestic_dns="$(toml_escape "$domestic_dns")"
	_foreign_dns="$(toml_escape "$foreign_dns")"
	_mmdb_path="$(toml_escape "$mmdb_path")"
	_ipv4_list="$(toml_escape "$ipv4_list")"
	_ipv6_list="$(toml_escape "$ipv6_list")"
	_gfwlist_path="$(toml_escape "$gfwlist_path")"
	_adblock_path="$(toml_escape "$adblock_path")"
	_special_upstream="$(toml_escape "$special_upstream")"

	cat > $CONF_FILE <<EOF
# Tsubamegaeshi-rs Configuration
# Auto-generated by luci-app-tsubamegaeshi-rs

listen = "${listen_str}"
log_level = "${_log_level}"

domestic_upstream = "${_domestic_dns}"
foreign_upstream = "${_foreign_dns}"

mmdb_path = "${_mmdb_path}"
cache_size = ${cache_size}
query_timeout_sec = ${query_timeout_sec}
enable_ipv6_aaaa = ${enable_ipv6}
max_in_flight = ${max_in_flight}
max_polluted_packets = ${max_polluted_packets}
trust_domestic_nodata_reply = ${trust_nodata}

domestic_countries = [$(for cc in $domestic_countries; do printf '"%s",' "$cc"; done | sed 's/,$//')]

ipv4_list = "${_ipv4_list}"
ipv6_list = "${_ipv6_list}"
EOF

	# GFWList
	if [ "$gfwlist" -eq 1 ]; then
		cat >> $CONF_FILE <<EOF

gfwlist_path = "${_gfwlist_path}"
gfbloom_fp_rate = ${gfbloom_fp_rate}
EOF
	fi

	# AdBlock
	if [ "$adblock" -eq 1 ]; then
		cat >> $CONF_FILE <<EOF

adblock_path = "${_adblock_path}"
adblock_fp_rate = ${adblock_fp_rate}
EOF
	fi

	# Special suffix
	if [ -n "$special_suffixes" ] && [ -n "$special_upstream" ]; then
		echo "" >> $CONF_FILE
		echo "special_upstream = \"${_special_upstream}\"" >> $CONF_FILE
		printf "special_suffixes = [" >> $CONF_FILE
		local first=1
		for suffix in $special_suffixes; do
			[ $first -eq 0 ] && printf "," >> $CONF_FILE
			printf "\"%s\"" "$(toml_escape "$suffix")" >> $CONF_FILE
			first=0
		done
		echo "]" >> $CONF_FILE
	fi

	# Force domains
	if [ -n "$force_domestic" ]; then
		echo "" >> $CONF_FILE
		printf "force_domestic_domains = [" >> $CONF_FILE
		local first=1
		for domain in $force_domestic; do
			[ $first -eq 0 ] && printf "," >> $CONF_FILE
			printf "\"%s\"" "$(toml_escape "$domain")" >> $CONF_FILE
			first=0
		done
		echo "]" >> $CONF_FILE
	fi

	if [ -n "$force_foreign" ]; then
		echo "" >> $CONF_FILE
		printf "force_foreign_domains = [" >> $CONF_FILE
		local first=1
		for domain in $force_foreign; do
			[ $first -eq 0 ] && printf "," >> $CONF_FILE
			printf "\"%s\"" "$(toml_escape "$domain")" >> $CONF_FILE
			first=0
		done
		echo "]" >> $CONF_FILE
	fi

	# Hosts
	local has_ipv4=0
	local has_ipv6=0

	config_foreach generate_hosts_ipv4 hosts_ipv4
	config_foreach generate_hosts_ipv6 hosts_ipv6

	# MarkSites
	config_foreach generate_marksite marksite
}

generate_hosts_ipv4() {
	local domain ips
	config_get domain $1 domain
	config_get ips $1 ips
	ips="$(echo "$ips" | tr ',' ' ')"

	[ -z "$domain" ] || [ -z "$ips" ] && return

	if [ $has_ipv4 -eq 0 ]; then
		echo "" >> $CONF_FILE
		echo "[hosts.ipv4]" >> $CONF_FILE
		has_ipv4=1
	fi

	local ip_count=0
	for ip in $ips; do ip_count=$((ip_count + 1)); done

	if [ $ip_count -eq 1 ]; then
		echo "\"$(toml_escape "$domain")\" = \"$(toml_escape "$ips")\"" >> $CONF_FILE
	else
		printf "\"%s\" = [" "$(toml_escape "$domain")" >> $CONF_FILE
		local first=1
		for ip in $ips; do
			[ $first -eq 0 ] && printf "," >> $CONF_FILE
			printf "\"%s\"" "$(toml_escape "$ip")" >> $CONF_FILE
			first=0
		done
		echo "]" >> $CONF_FILE
	fi
}

generate_hosts_ipv6() {
	local domain ips
	config_get domain $1 domain
	config_get ips $1 ips
	ips="$(echo "$ips" | tr ',' ' ')"

	[ -z "$domain" ] || [ -z "$ips" ] && return

	if [ $has_ipv6 -eq 0 ]; then
		echo "" >> $CONF_FILE
		echo "[hosts.ipv6]" >> $CONF_FILE
		has_ipv6=1
	fi

	local ip_count=0
	for ip in $ips; do ip_count=$((ip_count + 1)); done

	if [ $ip_count -eq 1 ]; then
		echo "\"$(toml_escape "$domain")\" = \"$(toml_escape "$ips")\"" >> $CONF_FILE
	else
		printf "\"%s\" = [" "$(toml_escape "$domain")" >> $CONF_FILE
		local first=1
		for ip in $ips; do
			[ $first -eq 0 ] && printf "," >> $CONF_FILE
			printf "\"%s\"" "$(toml_escape "$ip")" >> $CONF_FILE
			first=0
		done
		echo "]" >> $CONF_FILE
	fi
}

generate_marksite() {
	local section="$1"

	if [ -z "$(grep '^\[marksite' $CONF_FILE 2>/dev/null)" ]; then
		echo "" >> $CONF_FILE
		echo "[marksite]" >> $CONF_FILE
	fi

	local table_name domains
	config_get table_name $section table
	config_get domains $section domain
	printf "\"%s\" = [" "$(toml_escape "$table_name")" >> $CONF_FILE
	local first=1
	for d in $domains; do
		[ $first -eq 0 ] && printf "," >> $CONF_FILE
		printf "\"%s\"" "$(toml_escape "$d")" >> $CONF_FILE
		first=0
	done
	echo "]" >> $CONF_FILE
}

service_triggers() {
	return 0
}

save_dnsmasq_value() {
	local key="$1"
	local val="$2"
	# Always write the key; use __EMPTY__ sentinel for unset values
	# so restore knows to uci del rather than uci set.
	if [ -n "$val" ]; then
		printf "%s=%s\n" "$key" "$val" >> "$REDIRECT_LOCK_FILE"
	else
		printf "%s=__EMPTY__\n" "$key" >> "$REDIRECT_LOCK_FILE"
	fi
}

dhcp_setting() {
	if [ ! -f "$REDIRECT_LOCK_FILE" ]; then
		# Backup current dnsmasq settings to lock file
		save_dnsmasq_value rebind_protection "$(uci -q get dhcp.@dnsmasq[0].rebind_protection)"
		save_dnsmasq_value rebind_localhost "$(uci -q get dhcp.@dnsmasq[0].rebind_localhost)"
		save_dnsmasq_value noresolv "$(uci -q get dhcp.@dnsmasq[0].noresolv)"
		save_dnsmasq_value resolvfile "$(uci -q get dhcp.@dnsmasq[0].resolvfile)"
		save_dnsmasq_value cachesize "$(uci -q get dhcp.@dnsmasq[0].cachesize)"

		# Backup server list (uci get outputs space-separated, split by for)
		local srv
		for srv in $(uci -q get dhcp.@dnsmasq[0].server); do
			[ -n "$srv" ] && printf "server=%s\n" "$srv" >> "$REDIRECT_LOCK_FILE"
		done
	fi

	# dnsmasq server entry: wrap IPv6 in brackets
	local server_addr
	case "$listen_address" in
		*:*) server_addr="[${listen_address}]" ;;
		*)   server_addr="$listen_address" ;;
	esac

	uci -q delete dhcp.@dnsmasq[0].server
	uci add_list dhcp.@dnsmasq[0].server="${server_addr}#${listen_port}"
	uci set dhcp.@dnsmasq[0].rebind_protection='0'
	uci set dhcp.@dnsmasq[0].noresolv="1"
	uci set dhcp.@dnsmasq[0].cachesize='0'
	uci commit dhcp
}

restore_dhcp_setting() {
	if [ -f "$REDIRECT_LOCK_FILE" ]; then
		uci -q delete dhcp.@dnsmasq[0].server

		while IFS='=' read -r key val; do
			case "$key" in
				rebind_protection|rebind_localhost|noresolv|resolvfile|cachesize)
					if [ "$val" = "__EMPTY__" ]; then
						uci del "dhcp.@dnsmasq[0].$key"
					else
						uci set "dhcp.@dnsmasq[0].$key=$val"
					fi ;;
				server)
					uci add_list "dhcp.@dnsmasq[0].server=$val" ;;
			esac
		done < "$REDIRECT_LOCK_FILE"

		uci commit dhcp
		rm -f "$REDIRECT_LOCK_FILE"
	fi
}

reload_dnsmasq() {
	[ "$(/etc/init.d/dnsmasq status)" = "running" ] && /etc/init.d/dnsmasq restart
}

reload_service() {
	stop
	sleep 1
	start
}

start_service() {
	[ -x "$PROG" ] || {
		echo "tsubamegaeshi-rs: binary $PROG not found or not executable" >&2
		return 1
	}

	config_load "tsubamegaeshi-rs"
	config_foreach get_config "tsubamegaeshi-rs"
	[ $enabled -ne 1 ] && return 1

	has_ipv4=0
	has_ipv6=0

	generate_config

	procd_open_instance tsubamegaeshi-rs
	procd_set_param command $PROG
	procd_append_param command -c "$CONF_FILE"
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param respawn
	procd_close_instance tsubamegaeshi-rs

	[ "$redirect" -ne 1 ] && restore_dhcp_setting
	[ "$redirect" -eq 1 ] && dhcp_setting
	reload_dnsmasq
}

stop_service() {
	[ -f "$REDIRECT_LOCK_FILE" ] && restore_dhcp_setting
	reload_dnsmasq
}
