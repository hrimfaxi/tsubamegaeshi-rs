#!/bin/sh /etc/rc.common

USE_PROCD=1
START=75
STOP=15

BIN="/usr/bin/tsubamegaeshi-rs"
LOCK_FILE="/etc/tsubamegaeshi-rs/dnsmasq.lock"
LISTEN_PORT=5353

load_config() {
  config_load tsubamegaeshi-rs

  config_get ENABLED main enabled "1"
  config_get CONFIG_FILE main config "/etc/tsubamegaeshi-rs/config.toml"
  config_get RUN_USER main user nobody
  config_get NOFILE main nofile 1024768
  config_get DNS_HIJACK main dns_hijack "0"
}

takeover_dns() {
  # 保存原始值（只存一次，防止重复 start 覆盖）
  [ ! -f "$LOCK_FILE" ] && {
    printf "noresolv=%s\n" "$(uci -q get dhcp.@dnsmasq[0].noresolv)"
    printf "cachesize=%s\n" "$(uci -q get dhcp.@dnsmasq[0].cachesize)"
  } > "$LOCK_FILE"

  sed -i "/list server/d" /etc/config/dhcp
  uci add_list dhcp.@dnsmasq[0].server="127.0.0.1#$LISTEN_PORT"
  uci set dhcp.@dnsmasq[0].noresolv="1"
  uci set dhcp.@dnsmasq[0].cachesize="0"
  uci commit dhcp
  /etc/init.d/dnsmasq reload
}

restore_dns() {
  [ -f "$LOCK_FILE" ] || return 0

  sed -i "/list server/d" /etc/config/dhcp

  . "$LOCK_FILE"

  [ -n "$noresolv" ] && uci set dhcp.@dnsmasq[0].noresolv="$noresolv" \
                     || uci del dhcp.@dnsmasq[0].noresolv
  [ -n "$cachesize" ] && uci set dhcp.@dnsmasq[0].cachesize="$cachesize" \
                     || uci del dhcp.@dnsmasq[0].cachesize

  uci commit dhcp
  /etc/init.d/dnsmasq reload
  rm -f "$LOCK_FILE"
}

setup_nft_hijack() {
  nft delete table inet tsubame 2>/dev/null
  nft add table inet tsubame
  nft add chain inet tsubame prerouting \
    "{ type nat hook prerouting priority -95; policy accept; }"
  nft add rule inet tsubame prerouting \
    "meta nfproto { ipv4, ipv6 } udp dport 53 counter redirect to :$LISTEN_PORT"
}

start_service() {
  load_config

  [ "$ENABLED" -eq 0 ] && {
    echo "[*] service disabled"
    return 1
  }

  [ -x "$BIN" ] || {
    echo "[x] binary not found"
    return 1
  }

  [ -f "$CONFIG_FILE" ] || {
    echo "[x] config not found"
    return 1
  }

  "$BIN" -T -c "$CONFIG_FILE" >/dev/null || {
    echo "[x] config validation failed"
    return 1
  }

  procd_open_instance

  if [ -x /sbin/ujail ] && [ -e /etc/capabilities/tsubamegaeshi-rs.json ]; then
    procd_add_jail tsubamegaeshi-rs ronly requirejail
    procd_set_param capabilities /etc/capabilities/tsubamegaeshi-rs.json
    procd_set_param user "$RUN_USER"
    procd_set_param group "$RUN_USER"
    procd_set_param no_new_privs 1
    procd_add_jail_mount "/etc/tsubamegaeshi-rs"
    procd_add_jail_mount "/usr/sbin/nft"
  fi

  procd_set_param command "$BIN" -c "$CONFIG_FILE"
  procd_set_param user "$RUN_USER"

  # Open file limit
  procd_set_param limits nofile="$NOFILE $NOFILE"

  # restart policy (crash protection)
  procd_set_param respawn 3600 5 0

  # log to syslog
  procd_set_param stdout 1
  procd_set_param stderr 1

  # config watch (optional but safe even without reload_signal)
  procd_set_param file "$CONFIG_FILE"

  procd_close_instance

  takeover_dns

  # 可选：劫持局域网里绕过 dnsmasq 的设备
  if [ "$DNS_HIJACK" -eq 1 ] && [ -x /sbin/fw4 ]; then
    setup_nft_hijack
  fi
}

stop_service() {
  restore_dns
  nft delete table inet tsubame 2>/dev/null
}

reload_service() {
  echo "[*] restarting service (reload not supported)"
  restart
}

# vim: set sw=2 ts=2 et:
